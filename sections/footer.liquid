<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Company -->
      <div class="footer__column">
        <a href="#" class="footer__logo">
          APEX
        </a>
        <p class="footer__about">
          Premium fashion crafted for modern lifestyles. Timeless designs, exceptional
          quality, and effortless everyday comfort.
        </p>
        <div class="footer__social">
          <a href="#" class="footer__social-link">
            FB
          </a>
          <a href="#" class="footer__social-link">
            IG
          </a>
          <a href="#" class="footer__social-link">
            TW
          </a>
          <a href="#" class="footer__social-link">
            YT
          </a>
        </div>
      </div>
      <!-- Quick Links -->
      <div class="footer__column">
        <h3 class="footer__heading">
          Quick Links
        </h3>
        <ul class="footer__menu">
          <li>
            <a href="#">
              Home
            </a>
          </li>
          <li>
            <a href="#">
              Shop
            </a>
          </li>
          <li>
            <a href="#">
              Collections
            </a>
          </li>
          <li>
            <a href="#">
              About
            </a>
          </li>
          <li>
            <a href="#">
              Contact
            </a>
          </li>
        </ul>
      </div>
      <!-- Customer Support -->
      <div class="footer__column">
        <h3 class="footer__heading">
          Customer Support
        </h3>
        <ul class="footer__menu">
          <li>
            <a href="#">
              FAQ
            </a>
          </li>
          <li>
            <a href="#">
              Shipping
            </a>
          </li>
          <li>
            <a href="#">
              Returns
            </a>
          </li>
          <li>
            <a href="#">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="#">
              Terms & Conditions
            </a>
          </li>
        </ul>
      </div>
      <!-- Contact -->
      <div class="footer__column">
        <h3 class="footer__heading">
          Contact
        </h3>
        <ul class="footer__contact">
          <li>
            Email: support@apex.com
          </li>
          <li>
            Phone: +1 (234) 567-890
          </li>
          <li>
            New York, United States
          </li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <div class="footer__copyright">
        © 2026 Apex. All Rights Reserved.
      </div>
      <div class="footer__payments">
        <img src="{{ 'payment-icons.png' | asset_url }}" alt="Payment Methods">
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
.footer-section{
    background:#111;
}
.footer {
  
  color:#fff;
  padding:100px 0 30px;
}
.footer__grid {
  display:grid;
  grid-template-columns:2fr 1fr 1fr 1.2fr;
  gap:60px;
  padding-bottom:60px;
  border-bottom:1px solid rgba(255,255,255,.12);
}
.footer__logo {
  display:inline-block;
  margin-bottom:24px;
  font-size:34px;
  font-weight:700;
  color:#fff;
  text-decoration:none;
}
.footer__about {
  max-width:340px;
  color:#bdbdbd;
  line-height:1.8;
  margin-bottom:30px;
}
.footer__social {
  display:flex;
  gap:14px;
}
.footer__social-link {
  width:44px;
  height:44px;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:50%;
  background:#222;
  color:#fff;
  text-decoration:none;
  transition:.35s ease;
}
.footer__social-link:hover {
  background:#fff;
  color:#111;
}
.footer__heading {
  font-size:22px;
  margin-bottom:24px;
}
.footer__menu {
  list-style:none;
}
.footer__menu li {
  margin-bottom:16px;
}
.footer__menu a {
  color:#bdbdbd;
  text-decoration:none;
  transition:.3s;
}
.footer__menu a:hover {
  color:#fff;
}
.footer__contact {
  list-style:none;
}
.footer__contact li {
  color:#bdbdbd;
  margin-bottom:18px;
  line-height:1.7;
}
.footer__bottom {
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding-top:30px;
}
.footer__copyright {
  color:#999;
}
.footer__payments img {
  max-width:260px;
  width:100%;
  display:block;
}
/* -----------------------------
   Footer Polish
------------------------------ */

.footer__social-link {
  border:1px solid rgba(255,255,255,.08);
}
.footer__social-link:hover {
  transform:translateY(-3px);
  box-shadow:0 12px 30px rgba(255,255,255,.12);
}
.footer__menu a {
  display:inline-block;
}
.footer__menu a:hover {
  transform:translateX(6px);
}
.footer__payments img {
  opacity:.9;
}
/* -----------------------------
   Tablet
------------------------------ */

@media screen and (max-width:991px) {
  .footer {
  padding:80px 0 30px;
}
.footer__grid {
  grid-template-columns:repeat(2,1fr);
  gap:45px;
  padding-bottom:45px;
}
.footer__about {
  max-width:100%;
}
.footer__bottom {
  flex-direction:column;
  gap:20px;
  text-align:center;
}
}/* -----------------------------
   Mobile
------------------------------ */

@media screen and (max-width:767px) {
  .footer {
  padding:70px 0 25px;
}
.footer__grid {
  grid-template-columns:1fr;
  gap:40px;
  padding-bottom:40px;
}
.footer__logo {
  font-size:30px;
  margin-bottom:18px;
}
.footer__heading {
  font-size:20px;
  margin-bottom:18px;
}
.footer__menu li {
  margin-bottom:14px;
}
.footer__contact li {
  margin-bottom:14px;
}
.footer__social {
  gap:12px;
}
.footer__social-link {
  width:42px;
  height:42px;
}
.footer__payments img {
  max-width:220px;
  margin:0 auto;
}
.footer__copyright {
  font-size:14px;
}
}/* -----------------------------
   Small Mobile
------------------------------ */

@media screen and (max-width:480px) {
  .footer {
  padding:60px 0 20px;
}
.footer__logo {
  font-size:26px;
}
.footer__about {
  font-size:14px;
}
.footer__heading {
  font-size:18px;
}
.footer__payments img {
  max-width:180px;
}
}
 {% endstylesheet %}

