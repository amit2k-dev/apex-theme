<section class="logo-list">
  <div class="container">
    <div class="logo-list__header">
      <span class="logo-list__subtitle">
        TRUSTED BY
      </span>
      <h2 class="logo-list__title">
        Brands That Trust Our Quality
      </h2>
    </div>
    <div class="logo-list__grid">
      <div class="logo-item">
        <img src="{{ '12.png' | asset_url }}" alt="Brand Logo">
      </div>
      <div class="logo-item">
        <img src="{{ '13.png' | asset_url }}" alt="Brand Logo">
      </div>
      <div class="logo-item">
        <img src="{{ '14.png' | asset_url }}" alt="Brand Logo">
      </div>
      <div class="logo-item">
        <img src="{{ '15.png' | asset_url }}" alt="Brand Logo">
      </div>
      <div class="logo-item">
        <img src="{{ '16.png' | asset_url }}" alt="Brand Logo">
      </div>
      <div class="logo-item">
        <img src="{{ '17.png' | asset_url }}" alt="Brand Logo">
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.logo-list {
  padding:120px 0;
  background:#ffffff;
}
.logo-list__header {
  text-align:center;
  margin-bottom:60px;
}
.logo-list__subtitle {
  display:inline-block;
  margin-bottom:14px;
  font-size:13px;
  font-weight:600;
  letter-spacing:3px;
  text-transform:uppercase;
  color:#777;
}
.logo-list__title {
  font-size:48px;
  line-height:1.15;
  color:#111;
}
.logo-list__grid {
  display:grid;
  grid-template-columns:repeat(6,1fr);
  gap:30px;
  align-items:center;
}
.logo-item {
  height:120px;
  display:flex;
  align-items:center;
  justify-content:center;
  border:1px solid rgba(0,0,0,.06);
  border-radius:16px;
  background:#fff;
  transition:.35s ease;
}
.logo-item img {
  max-width:140px;
  max-height:80px;
  width:auto;
  height:auto;
  object-fit:contain;
  opacity:.65;
  transition:.35s ease;
}
.logo-item:hover {
  transform:translateY(-6px);
  box-shadow:0 20px 40px rgba(0,0,0,.08);
}
.logo-item:hover img {
  opacity:1;
  transform:scale(1.08);
}

/* -----------------------------
   Card Polish
------------------------------ */

.logo-item {
  box-shadow:0 8px 20px rgba(0,0,0,.04);
}
.logo-item img {
  filter:grayscale(100%);
}
.logo-item:hover {
  border-color:rgba(0,0,0,.12);
  box-shadow:0 20px 45px rgba(0,0,0,.08);
}
.logo-item:hover img {
  filter:grayscale(0);
}
/* -----------------------------
   Tablet
------------------------------ */

@media screen and (max-width:991px) {
  .logo-list {
  padding:90px 0;
}
.logo-list__header {
  margin-bottom:50px;
}
.logo-list__title {
  font-size:40px;
}
.logo-list__grid {
  grid-template-columns:repeat(3,1fr);
  gap:24px;
}
.logo-item {
  height:110px;
}
.logo-item img {
  max-width:120px;
  max-height:60px;
}
}/* -----------------------------
   Mobile
------------------------------ */

@media screen and (max-width:767px) {
  .logo-list {
  padding:70px 0;
}
.logo-list__header {
  margin-bottom:40px;
}
.logo-list__subtitle {
  font-size:12px;
  letter-spacing:2px;
}
.logo-list__title {
  font-size:32px;
}
.logo-list__grid {
  grid-template-columns:repeat(2,1fr);
  gap:18px;
}
.logo-item {
  height:90px;
  border-radius:12px;
}
.logo-item img {
  max-width:100px;
  max-height:60px;
}
}/* -----------------------------
   Small Mobile
------------------------------ */

@media screen and (max-width:480px) {
  .logo-list__title {
  font-size:28px;
}
.logo-list__grid {
  gap:14px;
}
.logo-item {
  height:80px;
}
.logo-item img {
  max-width:80px;
  max-height:60px;
}
}
 {% endstylesheet %}

