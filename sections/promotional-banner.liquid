<section class="promo-banner">
  <div class="container">
    <div class="promo-banner__grid">
      <!-- Banner 1 -->
      <a href="#" class="promo-card">
        <div class="promo-card__image">
          <img src="{{ '7.png' | asset_url }}" alt="Men Collection">
        </div>
        <div class="promo-card__overlay">
        </div>
        <div class="promo-card__content">
          <span class="promo-card__subtitle">
            New Collection
          </span>
          <h2 class="promo-card__title">
            Men's Fashion
          </h2>
          <p class="promo-card__description">
            Premium essentials designed for everyday comfort.
          </p>
          <span class="promo-card__button">
            Shop Now →
          </span>
        </div>
      </a>
      <!-- Banner 2 -->
      <a href="#" class="promo-card">
        <div class="promo-card__image">
          <img src="{{ '8.png' | asset_url }}" alt="Women Collection">
        </div>
        <div class="promo-card__overlay">
        </div>
        <div class="promo-card__content">
          <span class="promo-card__subtitle">
            Trending Now
          </span>
          <h2 class="promo-card__title">
            Women's Fashion
          </h2>
          <p class="promo-card__description">
            Elegant pieces crafted for modern lifestyles.
          </p>
          <span class="promo-card__button">
            Shop Now →
          </span>
        </div>
      </a>
    </div>
  </div>
</section>

{% stylesheet %}
.promo-banner {
  padding:120px 0;
}
.promo-banner__grid {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:32px;
}
.promo-card {
  position:relative;
  overflow:hidden;
  border-radius:20px;
  text-decoration:none;
  color:#fff;
  min-height:600px;
  display:flex;
  align-items:flex-end;
  transition:.35s ease;
}
.promo-card__image {
  position:absolute;
  inset:0;
}
.promo-card__image img {
  width:100%;
  height:100%;
  object-fit:cover;
  transition:.6s ease;
}
.promo-card__overlay {
  position:absolute;
  inset:0;
  background:linear-gradient(
        to top,rgba(0,0,0,.65),rgba(0,0,0,.15)
    );
}
.promo-card__content {
  position:relative;
  z-index:2;
  padding:50px;
}
.promo-card__subtitle {
  display:inline-block;
  margin-bottom:16px;
  font-size:13px;
  letter-spacing:3px;
  text-transform:uppercase;
}
.promo-card__title {
  font-size:48px;
  margin-bottom:18px;
  line-height:1.1;
}
.promo-card__description {
  font-size:18px;
  line-height:1.7;
  margin-bottom:35px;
  max-width:420px;
}
.promo-card__button {
  display:inline-flex;
  align-items:center;
  gap:10px;
  font-weight:600;
  transition:.3s;
}
.promo-card:hover img {
  transform:scale(1.08);
}
.promo-card:hover {
  transform:translateY(-8px);
}
.promo-card:hover .promo-card__button {
  gap:18px;
}

/* -----------------------------
   Card Shadow
------------------------------ */

.promo-card {
  box-shadow:0 10px 30px rgba(0,0,0,.08);
}
.promo-card:hover {
  box-shadow:0 30px 60px rgba(0,0,0,.15);
}
/* -----------------------------
   Content Animation
------------------------------ */

.promo-card__content {
  transition:.35s ease;
}
.promo-card:hover .promo-card__content {
  transform:translateY(-10px);
}
/* -----------------------------
   Tablet
------------------------------ */

@media screen and (max-width:991px) {
  .promo-banner {
  padding:90px 0;
}
.promo-banner__grid {
  grid-template-columns:1fr;
  gap:24px;
}
.promo-card {
  min-height:520px;
}
.promo-card__content {
  padding:40px;
}
.promo-card__title {
  font-size:40px;
}
.promo-card__description {
  font-size:16px;
}
}/* -----------------------------
   Mobile
------------------------------ */

@media screen and (max-width:767px) {
  .promo-banner {
  padding:70px 0;
}
.promo-card {
  min-height:420px;
  border-radius:16px;
}
.promo-card__content {
  padding:28px;
}
.promo-card__subtitle {
  font-size:12px;
  letter-spacing:2px;
}
.promo-card__title {
  font-size:32px;
  margin-bottom:14px;
}
.promo-card__description {
  font-size:15px;
  line-height:1.6;
  margin-bottom:24px;
}
}/* -----------------------------
   Small Mobile
------------------------------ */

@media screen and (max-width:480px) {
  .promo-card {
  min-height:360px;
}
.promo-card__content {
  padding:22px;
}
.promo-card__title {
  font-size:26px;
}
.promo-card__description {
  font-size:14px;
}
}
 {% endstylesheet %}


